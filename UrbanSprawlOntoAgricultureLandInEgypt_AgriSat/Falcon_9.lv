					SetResolutionTogether 0
					CoordinateSystem 0
					NumAzPoints      360
					AzimuthRes       1.002786
					MinAzimuth       -180.000000
					MaxAzimuth       180.000000
					NumElPoints      90
					ElevationRes     2.022472
					MinElevation     0.000000
					MaxElevation     180.000000
				END AzElPatternDef
			END AzElPattern
		END CntrAntAzEl
		BEGIN RCSContour
			Frequency 2997924580.000000
			ComputeType 0
		END RCSContour
		END ContourDefinition
	END ContourSet
    END Contours
    
